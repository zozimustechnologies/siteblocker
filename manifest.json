{
  "manifest_version": 3,
  "name": "Site Blocker",
  "version": "1.1.0",
  "description": "Block distracting websites to boost productivity. Manage up to 100 sites with easy toggle controls and optional child safety math challenge.",
  "author": "Zozimus Technologies",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Open Site Blocker"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "settings.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js", "icons/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
